{
  "info": {
    "name": "FieldNerve",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Vendor",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.environment.set(\"vendorId\", jsonData.data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/vendors",
          "host": [
            "http://localhost:3000"
          ],
          "path": [
            "vendors"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"name\":\"Test Vendor\",\"vendorType\":\"CONTRACTOR\",\"category\":\"CIVIL_CONSTRUCTION\",\"contactPerson\":\"John Doe\",\"phone\":\"1234567890\",\"email\":\"test@example.com\",\"operatingLocation\":\"Maharashtra\",\"rating\":4,\"safetyRating\":4.5}"
        }
      }
    },
    {
      "name": "Get Vendors",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:3000/vendors?category=CIVIL_CONSTRUCTION",
          "host": [
            "http://localhost:3000"
          ],
          "path": [
            "vendors"
          ],
          "query": [
            {
              "key": "category",
              "value": "CIVIL_CONSTRUCTION"
            }
          ]
        }
      }
    },
